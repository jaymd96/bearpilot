# bearpilot.env — per-user config for the bundled bash harness.
#
# Copy to ~/.config/bearpilot/env and fill in YOUR values, OR let `/bearpilot:setup`
# (or `./install.sh`) write it for you. The harness sources this file automatically;
# nothing here is committed — it is your private cluster identity.
#
# The MCP server + live dashboard read their own per-user config separately, from
# ~/.config/bear-harness/hosts.toml (see hosts.toml.example). /bearpilot:setup writes
# both from one set of answers, so you only state your identity once.
#
# Only your IDENTITY lives here. The universal BlueBEAR constants (QoS names, the a100
# GRES, the CUDA module) ship as real defaults in the harness — override them with the
# matching BB_* var only if they rotate.

export BB_USER="your-bluebear-username"            # e.g. abc123 — your CLUSTER login, NOT your laptop user
export BB_ACCOUNT="your-project-account"           # from: sacctmgr -nP show assoc user=$USER format=account,qos
export BB_RDS_ROOT="/rds/projects/g/your-project"  # /rds/projects/<first-letter-of-account>/<account>

# Optional:
# export BB_MAIL_USER="you@example.com"            # SLURM job-state email notifications
# export BB_HOME="/rds/homes/u/your-username"      # only if a script needs your cluster $HOME
