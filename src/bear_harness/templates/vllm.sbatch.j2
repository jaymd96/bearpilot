#!/usr/bin/env bash
#SBATCH --job-name={{ job_name }}
#SBATCH --account={{ account }}
#SBATCH --qos={{ qos }}
#SBATCH --gres={{ gpu_gres }}
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --mem={{ mem_gb }}G
#SBATCH --time={{ walltime }}
#SBATCH --output={{ runs_dir }}/{{ job_id }}/vllm-%j.out
#SBATCH --error={{ runs_dir }}/{{ job_id }}/vllm-%j.out
{% if mail_user %}
#SBATCH --mail-user={{ mail_user }}
#SBATCH --mail-type={{ mail_events }}
{% endif %}
#SBATCH --signal=B:TERM@30
#
# Auto-generated by bear-harness. Do not edit by hand.
# Template: vllm.sbatch.j2
#
# This script boots a vLLM server inside an Apptainer container, waits
# for /v1/models to answer 200, atomically publishes the endpoint JSON
# to {{ endpoints_dir }}/{{ job_id }}.json, then waits on the vLLM
# process. SIGTERM / SIGUSR1 / EXIT traps tear the server down and
# remove the endpoint file so stale references cannot confuse the next
# launch.

set -euo pipefail

echo "[vllm-sbatch] slurm_job_id=${SLURM_JOB_ID:-}"
echo "[vllm-sbatch] host=$(hostname)"
echo "[vllm-sbatch] start $(date -Iseconds)"

# ---------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------

module purge
module load {{ cuda_module }}

export HF_HOME="{{ hf_cache }}"
export HF_HUB_ENABLE_HF_TRANSFER=1
export TRANSFORMERS_OFFLINE=0
export VLLM_LOGGING_LEVEL=INFO

mkdir -p "{{ runs_dir }}/{{ job_id }}"
mkdir -p "{{ endpoints_dir }}"

# ---------------------------------------------------------------------
# Node-local scratch (BlueBEAR: advanced_jobs#use-local-disk-space).
# Heavy I/O belongs on /scratch, not the network file-store. SLURM does
# not set TMPDIR on BlueBEAR; node /tmp is small.
# ---------------------------------------------------------------------

BB_WORKDIR=""
if [[ -d /scratch && -w /scratch ]]; then
  BB_WORKDIR=$(mktemp -d "/scratch/${USER}_${SLURM_JOB_ID}.XXXXXX")
  export TMPDIR="$BB_WORKDIR"
  echo "[vllm-sbatch] node-local workdir $BB_WORKDIR"
fi

# ---------------------------------------------------------------------
# Pick a free port in [{{ port_low }}, {{ port_high }}]
# ---------------------------------------------------------------------

PORT=""
for candidate in $(seq {{ port_low }} {{ port_high }}); do
  if ! ss -ltn "sport = :$candidate" 2>/dev/null | grep -q LISTEN; then
    PORT="$candidate"
    break
  fi
done
if [[ -z "$PORT" ]]; then
  echo "[vllm-sbatch] no free port in [{{ port_low }}, {{ port_high }}]" >&2
  exit 1
fi
echo "[vllm-sbatch] bound port $PORT"

# ---------------------------------------------------------------------
# Credentials and endpoint paths
# ---------------------------------------------------------------------

# bh- prefix: token_urlsafe can lead with '-', which downstream argv
# parsers would read as an option flag.
API_KEY="bh-$(python3 -c 'import secrets; print(secrets.token_urlsafe(24))')"
HOSTNAME_FQDN="$(hostname -f)"
# Server ROOT, no /v1 — probe_endpoint and the anthropic SDK append
# their own /v1/... paths.
BASE_URL="http://${HOSTNAME_FQDN}:${PORT}"
# Named after the HARNESS job id: run_launch on the login node and the
# companion pipeline sbatch both poll this exact path.
ENDPOINT_FINAL="{{ endpoints_dir }}/{{ job_id }}.json"

cleanup() {
  echo "[vllm-sbatch] cleanup $(date -Iseconds)"
  if [[ -n "${VLLM_PID:-}" ]] && kill -0 "$VLLM_PID" 2>/dev/null; then
    kill -TERM "$VLLM_PID" 2>/dev/null || true
    sleep 5
    kill -KILL "$VLLM_PID" 2>/dev/null || true
  fi
  rm -f "$ENDPOINT_FINAL" 2>/dev/null || true
  if [[ -n "${BB_WORKDIR:-}" ]]; then
    rm -rf "$BB_WORKDIR" 2>/dev/null || true
  fi
}
trap cleanup EXIT TERM USR1

# ---------------------------------------------------------------------
# Stage the SIF onto node-local scratch when it fits — container start
# random-reads the image, which is slow (and antisocial) over /rds.
# One sequential cp, then mount the local copy; fall back to the RDS
# path if /scratch is absent, full, or the copy fails.
# ---------------------------------------------------------------------

SIF="{{ apptainer_sif }}"
if [[ -n "$BB_WORKDIR" ]]; then
  SIF_KB=$(du -k "{{ apptainer_sif }}" | cut -f1)
  FREE_KB=$(df -Pk "$BB_WORKDIR" | awk 'NR==2 {print $4}')
  if (( FREE_KB > SIF_KB + 1048576 )); then
    STAGE_START=$SECONDS
    if cp "{{ apptainer_sif }}" "$BB_WORKDIR/vllm-openai.sif"; then
      SIF="$BB_WORKDIR/vllm-openai.sif"
      echo "[vllm-sbatch] staged $((SIF_KB / 1024))MB SIF to scratch in $((SECONDS - STAGE_START))s"
    else
      rm -f "$BB_WORKDIR/vllm-openai.sif" 2>/dev/null || true
      echo "[vllm-sbatch] SIF staging failed — using RDS path" >&2
    fi
  else
    echo "[vllm-sbatch] insufficient /scratch space — using RDS path"
  fi
fi

# ---------------------------------------------------------------------
# Launch vLLM inside Apptainer
# ---------------------------------------------------------------------

apptainer run --nv \
  --bind "{{ hf_cache }}:{{ hf_cache }}" \
  --env HF_HOME="{{ hf_cache }}" \
  --bind "{{ runs_dir }}/{{ job_id }}:/workdir" \
  "$SIF" \
    --model "{{ model }}" \
    --served-model-name "{{ served_model_name }}" \
    --host 0.0.0.0 \
    --port "$PORT" \
    --api-key "$API_KEY" \
    --tensor-parallel-size {{ tensor_parallel_size }} \
{% if max_model_len is not none %}
    --max-model-len {{ max_model_len }} \
{% endif %}
{% if gpu_memory_utilization is not none %}
    --gpu-memory-utilization {{ gpu_memory_utilization }} \
{% endif %}
{% if dtype is not none %}
    --dtype {{ dtype }} \
{% endif %}
{% for arg in extra_args %}
    {{ arg }} \
{% endfor %}
    --enable-prefix-caching &
VLLM_PID=$!
echo "[vllm-sbatch] vllm pid=$VLLM_PID"

# ---------------------------------------------------------------------
# Poll /v1/models until it returns 200 (or boot timeout)
# ---------------------------------------------------------------------

READY=0
DEADLINE=$(( $(date +%s) + {{ boot_timeout_seconds }} ))
while [[ $(date +%s) -lt $DEADLINE ]]; do
  if ! kill -0 "$VLLM_PID" 2>/dev/null; then
    echo "[vllm-sbatch] vllm died before becoming ready" >&2
    exit 2
  fi
  if curl -fsS \
       -H "Authorization: Bearer $API_KEY" \
       "http://127.0.0.1:${PORT}/v1/models" > /dev/null 2>&1; then
    READY=1
    break
  fi
  sleep 5
done

if [[ "$READY" -ne 1 ]]; then
  echo "[vllm-sbatch] boot timeout after {{ boot_timeout_seconds }}s" >&2
  exit 3
fi

echo "[vllm-sbatch] ready at $BASE_URL"

# ---------------------------------------------------------------------
# Publish endpoint JSON atomically
# ---------------------------------------------------------------------

TMP_ENDPOINT="$(mktemp "{{ endpoints_dir }}/${SLURM_JOB_ID}.XXXXXX.json.tmp")"
cat > "$TMP_ENDPOINT" <<JSON
{
  "base_url": "$BASE_URL",
  "api_key": "$API_KEY",
  "model": "{{ served_model_name }}",
  "job_id": "$SLURM_JOB_ID"
}
JSON
mv -f "$TMP_ENDPOINT" "$ENDPOINT_FINAL"
echo "[vllm-sbatch] wrote endpoint $ENDPOINT_FINAL"

# ---------------------------------------------------------------------
# Block on the vLLM process. Traps handle cleanup.
# ---------------------------------------------------------------------

wait "$VLLM_PID"
