#!/usr/bin/env bash
#SBATCH --job-name={{ job_name }}
#SBATCH --account={{ account }}
#SBATCH --qos={{ pipeline_qos }}
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --mem={{ mem_gb }}G
#SBATCH --time={{ walltime }}
#SBATCH --output={{ runs_dir }}/{{ job_id }}/pipeline-%j.out
#SBATCH --error={{ runs_dir }}/{{ job_id }}/pipeline-%j.out
{% if vllm_job_id %}
#SBATCH --dependency=after:{{ vllm_job_id }}
{% endif %}
{% if mail_user %}
#SBATCH --mail-user={{ mail_user }}
#SBATCH --mail-type={{ mail_events }}
{% endif %}
#SBATCH --signal=B:USR1@60
#
# Auto-generated by bear-harness. Do not edit by hand.
# Template: pipeline.sbatch.j2
#
# Runs the program entrypoint with the resolved env vars. A coupled worker
# (one with a vLLM dependency: --dependency=after: means "launch once the
# server is running", NOT "after it succeeds") first waits for the endpoint
# JSON the companion server publishes; a model-less worker (ETL) skips that.

set -euo pipefail

echo "[pipeline-sbatch] slurm_job_id=${SLURM_JOB_ID:-}"
echo "[pipeline-sbatch] host=$(hostname)"
echo "[pipeline-sbatch] start $(date -Iseconds)"

module purge
{% if cuda_module %}
module load {{ cuda_module }}
{% endif %}

export PYTHONUNBUFFERED=1

mkdir -p "{{ runs_dir }}/{{ job_id }}"
mkdir -p "{{ output_dir }}"

{% if vllm_job_id %}
# ---------------------------------------------------------------------
# Wait for the vLLM endpoint file published by the companion job
# (only for coupled workers; a model-less preset like ETL has none)
# ---------------------------------------------------------------------

ENDPOINT_FILE="{{ endpoints_dir }}/{{ job_id }}.json"
DEADLINE=$(( $(date +%s) + {{ boot_timeout_seconds }} ))

while [[ $(date +%s) -lt $DEADLINE ]]; do
  if [[ -f "$ENDPOINT_FILE" ]]; then
    break
  fi
  # Short-circuit if vllm job is no longer queued or running.
  STATE="$(squeue -h -j {{ vllm_job_id }} -o %T 2>/dev/null || true)"
  if [[ -z "$STATE" ]]; then
    echo "[pipeline-sbatch] vllm job {{ vllm_job_id }} vanished before endpoint file appeared" >&2
    exit 2
  fi
  sleep 5
done

if [[ ! -f "$ENDPOINT_FILE" ]]; then
  echo "[pipeline-sbatch] timeout waiting for $ENDPOINT_FILE" >&2
  exit 3
fi

BASE_URL="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["base_url"])' "$ENDPOINT_FILE")"
API_KEY="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["api_key"])' "$ENDPOINT_FILE")"
MODEL_NAME="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["model"])' "$ENDPOINT_FILE")"

export MODEL_BASE_URL="$BASE_URL"
export MODEL_API_KEY="$API_KEY"
export MODEL_NAME="$MODEL_NAME"
{% endif %}
export BEAR_HARNESS_JOB_ID="{{ job_id }}"
export BEAR_HARNESS_OUTPUT_DIR="{{ output_dir }}"
export DATA_PIPELINE_STATUS_FILE="{{ status_file }}"
{% for key, value in extra_env.items() %}
export {{ key }}="{{ value }}"
{% endfor %}

# ---------------------------------------------------------------------
# Program-specific runtime prep (venv, install hooks)
# ---------------------------------------------------------------------

# Install hooks use relative paths (pip install -e '.') — they must run
# from the program root, not the sbatch submission directory.
cd "{{ program_root }}"

# Node-local scratch (BlueBEAR: advanced_jobs#use-local-disk-space).
# SLURM does not set TMPDIR here and node /tmp is small — the venv
# build belongs on /scratch.
BB_WORKDIR=""
if [[ -d /scratch && -w /scratch ]]; then
  BB_WORKDIR=$(mktemp -d "/scratch/${USER}_${SLURM_JOB_ID}.XXXXXX")
  export TMPDIR="$BB_WORKDIR"
  echo "[pipeline-sbatch] node-local workdir $BB_WORKDIR"
fi

VENV_DIR="${TMPDIR:-/tmp}/bear-harness-venv-{{ job_id }}"
if [[ ! -d "$VENV_DIR" ]]; then
  {{ python }} -m venv "$VENV_DIR"
fi
# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"
export PYTHON="$VENV_DIR/bin/python"

{% for cmd in install_commands %}
{{ cmd }}
{% endfor %}

cleanup() {
  echo "[pipeline-sbatch] cleanup $(date -Iseconds)"
{% for cmd in teardown_commands %}
  {{ cmd }} || true
{% endfor %}
  if [[ -n "${BB_WORKDIR:-}" ]]; then
    rm -rf "$BB_WORKDIR" 2>/dev/null || true
  fi
}
trap cleanup EXIT TERM USR1

# ---------------------------------------------------------------------
# Exec the program entrypoint (already substituted server-side)
# ---------------------------------------------------------------------

{{ entrypoint_command }}
